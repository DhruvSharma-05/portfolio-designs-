# Google Drive photo sync — copy to `.env` and fill in.
# Used by scripts/sync-drive.mjs (runs on `npm run sync` and `prebuild`).
# On Vercel, set these same values in Project Settings → Environment Variables.

# --- Auth: set ONE of the two below ---

# Preferred: a Google API key restricted to the Drive API. Works with
# folders shared "Anyone with the link → Viewer" (fine for public portfolio
# photos). Not blocked by the disableServiceAccountKeyCreation org policy.
GOOGLE_API_KEY=

# Alternative: a service-account key JSON (raw or base64) for PRIVATE folders
# shared with the service-account email. Leave blank if using GOOGLE_API_KEY.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Drive folder IDs (the long string in the folder URL after /folders/).
DRIVE_WORK_FOLDER_ID=1AFuId4un-d7Zrs1AXheAZrku6cAv99tR
DRIVE_GALLERY_FOLDER_ID=1MR1NSV3Zaib8u8Wolgw-2azdVN3sfIsd
DRIVE_PORTRAIT_FOLDER_ID=1G6V9t0CexDFc-KRv5R-LumwE0Le8CviX
