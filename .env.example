# Google Drive photo sync — copy to `.env` and fill in.
# Used by scripts/sync-drive.mjs (runs on `npm run sync` and `prebuild`).
# On Vercel, set these same four values in Project Settings → Environment Variables.

# Service-account key JSON. Paste the whole downloaded key on one line,
# OR base64-encode it (base64 -w0 key.json) and paste that. Never commit.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Drive folder IDs (the long string in the folder URL after /folders/).
# Share each folder with the service-account email (Viewer access).
DRIVE_WORK_FOLDER_ID=
DRIVE_GALLERY_FOLDER_ID=
DRIVE_PORTRAIT_FOLDER_ID=
