# ==================================================================
# Copy to `.env` and fill in. On Vercel, set the same values in
# Project Settings → Environment Variables.
#
# None of this is required to run the site locally — without it the
# site renders with placeholder photos and the example projects.
# ==================================================================

# --- Auth: set ONE of the two below -------------------------------

# Preferred (public portfolio sync): a Google API key restricted to the
# Drive API. Works with folders shared "Anyone with the link → Viewer"
# (fine for public portfolio photos). Not blocked by the
# disableServiceAccountKeyCreation org policy.
GOOGLE_API_KEY=

# Alternative / required for /admin: a service-account key JSON (raw or
# base64). Needed for PRIVATE folders and for the admin content API,
# which writes content.json. Paste the whole key on one line, OR
# base64-encode it (base64 -w0 key.json) and paste that. Never commit.
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Google Drive: photos -----------------------------------------
# Drive folder IDs (the long string in the folder URL after /folders/).
# For the service-account path, share each with the service-account
# email — Viewer is enough.
DRIVE_WORK_FOLDER_ID=1AFuId4un-d7Zrs1AXheAZrku6cAv99tR
DRIVE_GALLERY_FOLDER_ID=1MR1NSV3Zaib8u8Wolgw-2azdVN3sfIsd
DRIVE_PORTRAIT_FOLDER_ID=1G6V9t0CexDFc-KRv5R-LumwE0Le8CviX

# --- Admin (/admin) -----------------------------------------------
# The folder the admin photo-picker browses. It should CONTAIN one
# subfolder per shoot. Share it with the service account (Viewer).
DRIVE_ROOT_FOLDER_ID=

# File ID of a content.json that YOU create in Drive, then share with
# the service account as EDITOR.
#
# Create it yourself as an empty file named content.json — it must
# already exist. A service account has no storage quota of its own, so
# it can update a file someone else owns but cannot create one.
DRIVE_CONTENT_FILE_ID=

# Password for /admin. Make it long.
ADMIN_PASSWORD=

# Random string signing the admin session cookie. Generate with:
#   node -e "console.log(crypto.randomUUID())"
ADMIN_SESSION_SECRET=

# Vercel → Settings → Git → Deploy Hooks → create one, paste the URL.
# The "Publish" button calls this to rebuild the site.
VERCEL_DEPLOY_HOOK_URL=
