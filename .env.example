# ==================================================================
# Copy to `.env` and fill in. On Vercel, set the same values in
# Project Settings → Environment Variables.
#
# None of this is required to run the site locally — without it the
# site renders with placeholder photos and the example projects.
# ==================================================================

# --- Contentful: public portfolio photos ---------------------------
# Work / Gallery / Portrait photos are pulled from Contentful (a
# "Photo" content type — see README) instead of Drive, so the public
# site never depends on the Google API. Content Delivery API only
# (read-only, published entries).
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# --- Google service account: /admin only ---------------------------
# Required for /admin: a service-account key JSON (raw or base64).
# Used for the admin content API (writes content.json) and the photo
# picker's Drive browsing. Paste the whole key on one line, OR
# base64-encode it (base64 -w0 key.json) and paste that. Never commit.
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Admin (/admin) -----------------------------------------------
# The folder the admin photo-picker browses, and where new client
# delivery folders get created. It should CONTAIN one subfolder per
# shoot. Share it with the service account as EDITOR (not just Viewer —
# creating folders needs write access; children inherit it automatically).
#
# IMPORTANT: never set this folder itself to "Anyone with the link".
# Drive link-sharing is inherited by children, so every new delivery
# folder created inside it would be born publicly viewable, bypassing
# the whole per-client grant/revoke flow. Share it by name only (you +
# the service account), never by link.
DRIVE_ROOT_FOLDER_ID=

# File ID of a content.json that YOU create in Drive, then share with
# the service account as EDITOR.
#
# Create it yourself as an empty file named content.json — it must
# already exist. A service account has no storage quota of its own, so
# it can update a file someone else owns but cannot create one.
DRIVE_CONTENT_FILE_ID=

# Password for /admin. Make it long.
ADMIN_PASSWORD=

# Random string signing the admin session cookie. Generate with:
#   node -e "console.log(crypto.randomUUID())"
ADMIN_SESSION_SECRET=

# Vercel → Settings → Git → Deploy Hooks → create one, paste the URL.
# The "Publish" button calls this to rebuild the site.
VERCEL_DEPLOY_HOOK_URL=

# --- Client delivery: ZIP download ----------------------------------
# Caps on the ZIP a client can download directly from /client (built on
# the fly inside one serverless function call, so it can't be
# unbounded). Above either limit, only "Open in Google Drive" is
# offered instead — Drive zips folders of any size just fine, just not
# through us. Defaults if left blank: 400 files / 1500 MB.
DOWNLOAD_MAX_FILES=
DOWNLOAD_MAX_MB=

# --- SMTP: emailing a client their access code -----------------------
# Any provider works — Gmail (use an App Password, not your normal
# login password), SendGrid, Mailgun, your own mail server, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Shown as the From address. Leave blank to send as SMTP_USER.
SMTP_FROM=
